# Solana RPC Endpoint
# For development, use devnet: https://api.devnet.solana.com
# For production, use mainnet: https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional: Custom WebSocket endpoint
# NEXT_PUBLIC_SOLANA_WSS_URL=wss://api.devnet.solana.com

# Optional: Helius API key (for enhanced APIs)
# HELIUS_API_KEY=your_helius_api_key

# Optional: Debug mode
# NEXT_PUBLIC_DEBUG=true